{
  "rewrites": [
    {
      "source": "/admin/app/views/((?!.*\\.).*)",
      "destination": "/admin/app/views/index.html"
    },
    {
      "source": "/client/((?!.*\\.).*)",
      "destination": "/client/index.html"
    },
    {
      "source": "/((?!admin/app/views|client|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}